---
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<h2><a href="/">DevToolRadar</a></h2>
		<div class="internal-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/blog">Blog</HeaderLink>
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0 1.5em;
		background: #0f172a;
	}
	h2 {
		margin: 0;
		font-size: 1em;
	}
	h2 a,
	h2 a.active {
		text-decoration: none;
		color: #fff;
		font-weight: 700;
		letter-spacing: 0.01em;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 760px;
		margin: 0 auto;
	}
	nav a {
		padding: 1em 0.5em;
		color: #94a3b8;
		border-bottom: 3px solid transparent;
		text-decoration: none;
		font-size: 0.9em;
		transition: color 0.15s;
	}
	nav a:hover {
		color: #fff;
	}
	nav a.active {
		color: #fff;
		border-bottom-color: var(--accent);
	}
</style>