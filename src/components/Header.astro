---
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<h2><a href="/">DevToolRadar</a></h2>
		<div class="internal-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/blog">Blog</HeaderLink>
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: #0f172a;
	}
	h2 {
		margin: 0;
		font-size: 1em;
		min-width: 0;
	}
	h2 a,
	h2 a.active {
		text-decoration: none;
		color: #fff;
		font-weight: 700;
		letter-spacing: 0.01em;
		white-space: nowrap;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		flex-wrap: wrap;
		gap: 0.25em;
		max-width: 760px;
		margin: 0 auto;
		padding: 0.25em 0;
	}
	.internal-links {
		display: flex;
		flex-shrink: 0;
	}
	nav a {
		padding: 0.75em 0.5em;
		color: #94a3b8;
		border-bottom: 3px solid transparent;
		text-decoration: none;
		font-size: 0.9em;
		transition: color 0.15s;
		white-space: nowrap;
	}
	nav a:hover {
		color: #fff;
	}
	nav a.active {
		color: #fff;
		border-bottom-color: var(--accent);
	}

	@media (max-width: 284px) {
		header {
			padding: 0 0.5em;
		}
		h2 a {
			font-size: 0.85em;
		}
		nav a {
			padding: 0.6em 0.35em;
			font-size: 0.8em;
		}
	}
</style>