---
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<h2><a href="/">
			<svg class="icon" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
				<path fill-rule="evenodd" clip-rule="evenodd" d="M24 44C35.0457 44 44 35.0457 44 24C44 12.9543 35.0457 4 24 4C12.9543 4 4 12.9543 4 24C4 35.0457 12.9543 44 24 44Z" stroke="currentColor" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"/>
				<path fill-rule="evenodd" clip-rule="evenodd" d="M24 34C29.5228 34 34 29.5228 34 24C34 18.4772 29.5228 14 24 14C18.4772 14 14 18.4772 14 24C14 29.5228 18.4772 34 24 34Z" stroke="currentColor" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"/>
				<path d="M24 4V44" stroke="currentColor" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"/>
				<path d="M4 24.0083L44 24.0083" stroke="currentColor" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"/>
			</svg>
			DevToolRadar</a></h2>
		<div class="internal-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/blog">Blog</HeaderLink>
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: #0f172a;
	}
	h2 {
		margin: 0;
		font-size: 1em;
		min-width: 0;
	}
	h2 a,
	h2 a.active {
		display: flex;
		align-items: center;
		gap: 0.5em;
		text-decoration: none;
		color: #fff;
		font-weight: 700;
		letter-spacing: 0.01em;
		white-space: nowrap;
	}
	.icon {
		width: 24px;
		height: 24px;
		flex-shrink: 0;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		flex-wrap: wrap;
		gap: 0.25em;
		max-width: 760px;
		margin: 0 auto;
		padding: 0.25em 0;
	}
	.internal-links {
		display: flex;
		flex-shrink: 0;
	}
	nav a {
		padding: 0.75em 0.5em;
		color: #94a3b8;
		border-bottom: 3px solid transparent;
		text-decoration: none;
		font-size: 0.9em;
		transition: color 0.15s;
		white-space: nowrap;
	}
	nav a:hover {
		color: #fff;
	}
	nav a.active {
		color: #fff;
		border-bottom-color: var(--accent);
	}

	@media (max-width: 284px) {
		header {
			padding: 0 0.5em;
		}
		h2 a {
			font-size: 0.85em;
		}
		nav a {
			padding: 0.6em 0.35em;
			font-size: 0.8em;
		}
	}
</style>