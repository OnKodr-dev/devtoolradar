---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="DevToolRadar" description="Honest reviews and comparisons of AI tools for developers." />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<h1>DevToolRadar</h1>
				<p>Honest reviews and comparisons of AI tools for developers.</p>
			</section>

			<section class="cards">
				{posts.map((post) => (
					<a class="card" href={`/blog/${post.id}/`}>
						<p class="date"><FormattedDate date={post.data.pubDate} /></p>
						<h2>{post.data.title}</h2>
						{post.data.description && <p class="desc">{post.data.description}</p>}
					</a>
				))}
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		max-width: 760px;
		margin: 0 auto;
		padding: 2rem 1.5rem;
	}

	.hero {
		margin-bottom: 3rem;
		padding-bottom: 2rem;
		border-bottom: 1px solid #e5e7eb;
	}

	.hero h1 {
		font-size: 2.2rem;
		margin: 0 0 0.4rem;
	}

	.hero p {
		margin: 0;
		color: #6b7280;
		font-size: 1rem;
	}

	.cards {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.card {
		display: block;
		padding: 1.5rem;
		border: 1px solid #e5e7eb;
		border-radius: 10px;
		text-decoration: none;
		color: inherit;
		transition: border-color 0.15s, box-shadow 0.15s;
	}

	.card:hover {
		border-color: var(--accent);
		box-shadow: 0 2px 12px rgba(0, 0, 0, 0.06);
	}

	.date {
		font-size: 0.82rem;
		color: #9ca3af;
		margin: 0 0 0.5rem;
	}

	.card h2 {
		font-size: 1.15rem;
		margin: 0 0 0.4rem;
		line-height: 1.4;
	}

	.desc {
		font-size: 0.92rem;
		color: #6b7280;
		margin: 0;
		line-height: 1.5;
	}
</style>
